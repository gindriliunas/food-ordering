{
  "name": "food-ordering-api",
  "version": "1.0.0",
  "description": "Serverless Food Ordering API for kitchen ingredient orders",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.js",
    "build:frontend": "npm --prefix frontend run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm --prefix frontend install && npm run build:frontend"
  },
  "keywords": [
    "aws",
    "lambda",
    "serverless",
    "food-ordering"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/client-sns": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "esbuild": "^0.25.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  }
}
